                    transform: rotate(90deg)
                    transform-origin: center
                */

        #selection-p1, #selection-p2
            width 30%

        #display-selection-p1, #display-selection-p2
            list-style: none;
            margin: 0;
            padding: 0;

       #selection-thumb-container
            width 30%

            

        #list-thumbs
            list-style: none;
            padding: 0;
            margin: 0;
            display: flex
            flex-wrap: wrap
            align-items: center
            align-content: center
