#scene-game-play
    header
        height: 3rem
        #game-timer-bar-container
            padding: 0.5rem
            width: 100%
            #game-time-bar
                background-color: black
                transition: width 0.1s linear;
                color: white
                margin-right: auto
                margin-left: auto
                border-radius: 1rem
    #game-play-contianer
        display: flex
        justify-content: space-between
        text-align: center

        #card-withdraw-container
            display: flex
            flex-wrap: wrap
            justify-content: center
            #card-message
                width: 100%
                font-size: 1.2rem
                font-weight: 600

            #card-reveal
                width: 5rem
                display: flex
                justify-content: center
                align-items: center

                #card-points
                    font-size: 2rem


        .score-board
            width: 30%

            .points
                font-size: 3rem

    .controller.not-current-turn
        opacity: 0.3
        background-color: #888


