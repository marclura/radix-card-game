.character-skill-list
    list-style: none
    margin: 0
    padding: 0
    width: 100%

    .skill-bar-container
        bar-height = 1.2rem
        background-color: #ccc
        border: 1px solid black
        padding: 0.1rem
        padding-left: 0.15rem
        border-radius: (bar-height / 2)
        height: bar-height

        .skill-bar
            font-size: (bar-height * 0.55)
            height: (bar-height - 0.3rem)
            background-color: white
            border-radius: ((bar-height - 0.1rem ) / 2)
            padding-left: 0.2rem
            text-align: left
