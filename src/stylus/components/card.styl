.card-decks-container
    display: flex
    width: 100%
    justify-content: space-between

    for color, value in colorMap
        &[data-color={color}]
            .card-deck
                border-color: value

.card
    aspect-ratio: 1 / 2
    border-radius: 0.6rem
    border: 0.15rem solid $primary

.card-deck
    width: 20%
    background-repeat: no-repeat
    background-position: center center
    background-size: 70%

.card-deck-1
    background-image: url('../../assets/cards/card-icon-1.svg')

.card-deck-2
    background-image: url('../../assets/cards/card-icon-2.svg')

.card-deck-3
    background-image: url('../../assets/cards/card-icon-3.svg')   
