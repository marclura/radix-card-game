#selection-characters-thumbnail
    .character-thumbnail
        margin: 1rem
        padding: 1rem
        width: 100%
        height: 60px

    .p1-selection
        border-left: 1rem white solid
    
    .p2-selection
        border-right: 1rem white solid


.character-card
    margin: 1rem
    padding: 1rem
    display: none

    &.active
        display: block

    .character-bar
        height: 10px
        background-color: yellow

        & + .character-bar
            margin-top: 0.3rem