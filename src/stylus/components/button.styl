button
    border: border-size solid $primary
    text-align: center
    box-sizing: border-box
    aspect-ratio: 1 / 1
    border-radius: 50%
    width: 33%
    padding: 1rem

.button.disabled
    background-color: $disabled
    color: $background
    border-color: $disabled-dark

.btn-icon
    fill: none
    stroke: $primary
    stroke-width: 1.2rem
    aspect-ratio: 1 / 1

.btn-arrow-up
    transform: rotate(180deg)

button:active
    background-color: $primary
    color: $background
    .btn-icon
        stroke: $background

button.disabled
    border-color: $disabled-bg !important
    background-color: $disabled-bg !important
    color: $disabled-content !important
    .btn-icon
        stroke: $disabled-content !important